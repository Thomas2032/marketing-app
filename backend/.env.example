# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# LLM
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://marketing:marketing@localhost:5432/marketing

# Object storage (S3 or Cloudflare R2)
STORAGE_BUCKET=marketing-assets
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto
# For R2: https://<account_id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT_URL=
# Public CDN base URL for serving images
STORAGE_PUBLIC_BASE_URL=

# Redis queue (set USE_QUEUE=true and run worker with docker compose --profile queue)
REDIS_URL=redis://localhost:6379/0
USE_QUEUE=false
