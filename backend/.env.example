# =============================================================================
# Application
# =============================================================================
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# LLM — unified config
# Provider declares which protocol/endpoint path to use.
# =============================================================================

# Provider: openai | anthropic | gemini
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-...
LLM_MODEL=claude-haiku-4-5-20251001
LLM_API_BASE=https://www.deeprouter.top

# --- Provider path rules (for reference) ---
# openai    →  {LLM_API_BASE}/v1           (chat/completions)
# anthropic →  {LLM_API_BASE}              (messages)
# gemini    →  {LLM_API_BASE}/v1beta       (generateContent)
#
# --- Common configs ---
# Official OpenAI:   LLM_PROVIDER=openai    LLM_API_BASE=  (leave empty)  LLM_MODEL=gpt-4o-mini
# DeepRouter OpenAI: LLM_PROVIDER=openai    LLM_API_BASE=https://www.deeprouter.top  LLM_MODEL=gpt-4o-mini
# DeepRouter Claude: LLM_PROVIDER=anthropic LLM_API_BASE=https://www.deeprouter.top  LLM_MODEL=claude-haiku-4-5-20251001
# DeepRouter Gemini: LLM_PROVIDER=gemini    LLM_API_BASE=https://www.deeprouter.top  LLM_MODEL=gemini-2.5-flash
# Official Anthropic: LLM_PROVIDER=anthropic LLM_API_BASE=  (leave empty)  LLM_MODEL=claude-haiku-4-5-20251001
# Official Gemini:    LLM_PROVIDER=gemini   LLM_API_BASE=  (leave empty)  LLM_MODEL=gemini-2.5-flash
# Ollama (local):    LLM_PROVIDER=openai    LLM_API_BASE=http://localhost:11434  LLM_MODEL=llama3.2

# =============================================================================
# PostgreSQL
# =============================================================================
DATABASE_URL=postgresql+asyncpg://marketing:marketing@localhost:5432/marketing

# =============================================================================
# Object Storage (AWS S3 or Cloudflare R2)
# =============================================================================
STORAGE_BUCKET=marketing-assets
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto
# For Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT_URL=
# Public CDN base URL for serving images
STORAGE_PUBLIC_BASE_URL=

# =============================================================================
# Redis Queue (Optional)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
USE_QUEUE=false
